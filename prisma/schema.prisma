generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Stores CMS content and admin-auth state as JSON documents, one row per key
// (e.g. "cms" for site content, "admin-auth" for the admin password/reset).
// This replaces the read-only-filesystem data/*.json files so admin edits and
// uploads persist on Amplify SSR.
model CmsDocument {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

enum AdminRole {
  ADMIN
}

enum ContentStatus {
  ACTIVE
  INACTIVE
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Category {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String?
  displayOrder Int           @default(0)
  status       ContentStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  galleryImages GalleryImage[]
}

model GalleryImage {
  id         String        @id @default(cuid())
  title      String
  slug       String        @unique
  description String?
  imageUrl   String
  publicId   String?
  categoryId String?
  tags       String?
  seoTitle   String?
  metaDescription String?
  altText    String
  keywords   String?
  featured   Boolean       @default(false)
  status     ContentStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  category   Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model AboutContent {
  id              String   @id @default(cuid())
  aboutText       String
  chefName        String
  chefDescription String
  chefImageUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TeamMember {
  id           String        @id @default(cuid())
  name         String
  designation  String
  bio          String?
  photoUrl     String?
  displayOrder Int           @default(0)
  status       ContentStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ContactSetting {
  id             String   @id @default(cuid())
  phone          String
  email          String
  address        String
  whatsappNumber String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WebsiteSetting {
  id           String   @id @default(cuid())
  logoUrl      String?
  footerText   String?
  instagramUrl String?
  facebookUrl  String?
  whatsappUrl  String?
  googleUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
